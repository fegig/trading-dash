# Local dev: copy to .env — leave VITE_API_URL empty to use Vite proxy (see vite.config.ts).
VITE_API_URL=
VITE_WS_URL=ws://localhost:8787
VITE_API_KEY=
VITE_APP_URL=http://localhost:4000
VITE_APP_ENV=development

# Production: `vite build` reads .env.production (NOT wrangler.jsonc vars).
# Wrangler vars are for the asset worker runtime; they do not rebuild env into JS.
# Edit dashboard/.env.production or set the same VITE_* in your CI / Cloudflare Pages env.
