{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "trading-dash",
    "main": "src/spa-og-worker.ts",
    "compatibility_date": "2025-10-27",
    "compatibility_flags": ["nodejs_compat"],
    "assets": {
        "directory": "dist",
        "binding": "ASSETS",
        "not_found_handling": "single-page-application",
        "run_worker_first": true
    },
    "env": {
        "development": {
            "vars": {
                "VITE_API_URL": "http://localhost:8787",
                "VITE_WS_URL": "ws://localhost:8787",
                "VITE_API_KEY": "hdsuuj-489hjs-Hkdwse-0823kjhsd",
                "VITE_APP_URL": "http://localhost:4000",
                "VITE_APP_ENV": "development",
                "SITE_CONFIG_URL": "http://localhost:8787/public/site-config",
                "VITE_SITE_NAME_FALLBACK": "JFM Capitals"
            }
        },
        "production": {
            "vars": {
                "VITE_API_URL": "https://api.jfmcapitals.com",
                "VITE_WS_URL": "wss://api.jfmcapitals.com",
                "VITE_API_KEY": "hdsuuj-489hjs-Hkdwse-0823kjhsd",
                "VITE_APP_URL": "https://jfmcapitals.com",
                "VITE_APP_ENV": "production",
                "SITE_CONFIG_URL": "https://api.jfmcapitals.com/public/site-config",
                "VITE_SITE_NAME_FALLBACK": "JFM Capitals"
            }
        }
    },
    "route":"jfmcapitals.com"
}