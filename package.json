{
  "name": "trading-dash-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Trading dashboard monorepo",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter dashboard --filter backend run dev",
    "dev:dash": "pnpm run dev --filter dashboard",
    "dev:backend": "pnpm run dev --filter backend",
    "build": "pnpm run -r build",
    "build:dash": "pnpm run build --filter dashboard",
    "build:backend": "pnpm run build --filter backend",
    "lint": "pnpm run -r lint",
    "typecheck": "pnpm run -r typecheck",
    "deploy:backend": "pnpm run deploy --filter backend",
    "deploy:dash": "pnpm run deploy --filter dashboard",
    "db:generate": "pnpm run db:generate --filter backend",
    "db:migrate": "pnpm run db:migrate --filter backend"
  }
}
